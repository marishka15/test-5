    "@testing-library/jest-dom": "^6.9.1",
    "babel-loader": "^9.2.1",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "7.0.0",
    "eslint": "9.20.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-jest": "28.11.0",
    "eslint-plugin-prettier": "5.2.3",
    "file-loader": "^6.2.0",
    "globals": "15.14.0",
    "html-loader": "5.1.0",
